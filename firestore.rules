rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- Helpers ----------

    function signedIn() {
      return request.auth != null;
    }

    function userDocPath(orgId, uid) {
      return /databases/$(database)/documents/orgs/$(orgId)/users/$(uid);
    }

    function hasUserDoc(orgId, uid) {
      return exists(userDocPath(orgId, uid));
    }

    function myRole(orgId) {
      return signedIn() && hasUserDoc(orgId, request.auth.uid)
        ? get(userDocPath(orgId, request.auth.uid)).data.role
        : null;
    }

    function isDriver(orgId) {
      return myRole(orgId) == 'driver' || myRole(orgId) == 'admin';
    }

    function isAdmin(orgId) {
      return myRole(orgId) == 'admin';
    }

    function isMember(orgId) {
      return signedIn() && hasUserDoc(orgId, request.auth.uid);
    }

    function orgIsActive(orgId) {
      return get(/databases/$(database)/documents/orgs/$(orgId)).data.subscriptionStatus
        in ['trialing', 'active'];
    }

    // ---------- Public org slug lookup (org selector screen) ----------
    // Anyone (unauthenticated) can list orgs to find their school/venue.
    // Server-side admin SDK writes these — clients cannot.
    match /orgSlugs/{slug} {
      allow read: if true;
      allow write: if false;
    }

    // ---------- Org invite codes ----------
    // Only the backend creates invites; users claim them server-side.
    match /orgInvites/{inviteCode} {
      allow read, write: if false;
    }

    // ---------- Org applications ----------
    // Created by POST /orgs/create (backend admin SDK). Internal review only.
    // No client should ever read or write these directly.
    match /orgApplications/{orgId} {
      allow read, write: if false;
    }

    // ---------- Org document ----------
    // Any member can read their org doc (stops, mapCenter, subscriptionStatus, authMethod).
    // Admins may update a limited set of fields (stops, map, branding, auth).
    // Billing/subscription fields are server-only via Stripe webhooks.
    match /orgs/{orgId} {
      allow read: if isMember(orgId);

      allow update: if signedIn()
        && isAdmin(orgId)
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['stops', 'routes', 'mapCenter', 'mapBoundingBox', 'logoUrl',
                      'primaryColor', 'name', 'updatedAt']);

      allow create, delete: if false;
    }

    // ---------- Users ----------
    match /orgs/{orgId}/users/{uid} {
      // Users read their own doc only.
      allow read: if signedIn() && request.auth.uid == uid;

      // Create own profile on first login (role must be student; elevated roles only via backend).
      allow create: if signedIn()
        && request.auth.uid == uid
        && request.resource.data.orgId == orgId
        && request.resource.data.role == 'student';

      // Update own profile but never change role or orgId.
      allow update: if signedIn()
        && request.auth.uid == uid
        && request.resource.data.role == resource.data.role
        && request.resource.data.orgId == orgId
        && orgIsActive(orgId);

      allow delete: if false;
    }

    // ---------- Public user profiles ----------
    match /orgs/{orgId}/publicUsers/{uid} {
      // Any member of the same org can read (e.g. drivers see student names).
      allow read: if isMember(orgId);

      // Users manage their own public profile.
      allow create, update: if signedIn()
        && request.auth.uid == uid
        && orgIsActive(orgId);

      allow delete: if false;
    }

    // ---------- Bus locations ----------
    match /orgs/{orgId}/buses/{busId} {
      // Any org member can read bus locations (students see buses on map).
      allow read: if isMember(orgId);

      // Only the authenticated driver may write their own bus doc (docId == uid).
      allow create, update: if signedIn()
        && isDriver(orgId)
        && request.auth.uid == busId
        && orgIsActive(orgId);

      allow delete: if false;
    }

    // ---------- Stop requests ----------
    match /orgs/{orgId}/stopRequests/{requestId} {
      allow read: if signedIn() && (
        isDriver(orgId)
        || resource.data.studentUid == request.auth.uid
        || resource.data.status == 'accepted'
      );

      // Student creates their own pending request.
      allow create: if signedIn()
        && request.resource.data.studentUid == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.orgId == orgId
        && request.resource.data.stopId is string
        && orgIsActive(orgId);

      allow update: if signedIn() && (
        (
          // Student cancels their own pending request.
          resource.data.studentUid == request.auth.uid
          && resource.data.status == 'pending'
          && request.resource.data.status in ['pending', 'cancelled']
        )
        ||
        (
          // Driver accepts an unclaimed request.
          isDriver(orgId)
          && resource.data.status == 'pending'
          && resource.data.driverUid == null
          && request.resource.data.status == 'accepted'
          && request.resource.data.driverUid == request.auth.uid
        )
        ||
        (
          // Driver completes or cancels their own accepted request.
          isDriver(orgId)
          && resource.data.status == 'accepted'
          && resource.data.driverUid == request.auth.uid
          && request.resource.data.status in ['completed', 'cancelled']
          && request.resource.data.driverUid == request.auth.uid
        )
      );

      allow delete: if false;
    }

    // ---------- Boarding counts ----------
    match /orgs/{orgId}/boardingCounts/{id} {
      allow create: if signedIn() && isDriver(orgId) && orgIsActive(orgId);
      allow read: if signedIn() && (isAdmin(orgId) || isDriver(orgId));
      allow update, delete: if false;
    }

    // ---------- Default deny ----------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
